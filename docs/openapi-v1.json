  "components": {
    "schemas": {
      "AuthUserResponse": {
        "required": [
          "id",
          "email",
          "role"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          }
        }
      },
      "CompleteTodoRequest": {
        "required": [
          "isCompleted",
          "rowVersion"
        ],
        "type": "object",
        "properties": {
          "isCompleted": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "rowVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "uint32"
          }
        },
        "description": "Toggle completion. `RowVersion` mandatory; mismatch returns 409 (same\nconcurrency contract as PUT). Without that, complete + edit interleave silently."
      },
      "CreateTodoRequest": {
        "required": [
          "title",
          "description",
          "dueDate",
          "priority",
          "tags"
        ],
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "dueDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "priority": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Priority"
              }
            ]
          },
          "tags": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          }
        },
        "description": "Create payload. Server-set fields (Id, UserId, CreatedAt, UpdatedAt, RowVersion,\nIsCompleted) are intentionally absent — the server populates them. `Priority`\nand `Tags` default to Priority.Low and `[]` when null."
      },
      "LoginRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "PagedResultOfTodoResponse": {
        "required": [
          "items",
          "page",
          "pageSize",
          "total",
          "hasNext"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TodoResponse"
            }
          },
          "page": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "pageSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "total": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "hasNext": {
            "type": "boolean"
          }
        }
      },
      "Priority": {
        "enum": [
          "Low",
          "Medium",
          "High"
        ],
        "description": "Todo priority. Stored as text in SQLite via a string conversion for readability\nand migration safety (numeric ordinals can be reordered by mistake)."
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RegisterAcknowledgement": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "description": "Uniform register acknowledgement. Both branches — \"new account created\"\nAND \"email already in use\" — return this same shape with a 200 status,\nerasing the response-body register enumeration oracle. The \"did\nregistration actually succeed\" question is answered out-of-band by the\npresence of an auth cookie + a successful follow-up `/me` probe.\nSee docs/decisions.md."
      },
      "RegisterRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "description": "Register payload. `Role` is intentionally absent — never accept it from\na request DTO. Extra JSON fields ride along but cannot influence the C# type."
      },
      "Role": {
        "enum": [
          "Basic",
          "Admin"
        ],
        "description": "Application-level role for a User. Server-set only; never accepted from a request DTO."
      },
      "TodoResponse": {
        "required": [
          "id",
          "title",
          "description",
          "dueDate",
          "priority",
          "isCompleted",
          "completedAt",
          "tags",
          "rowVersion",
          "createdAt",
          "updatedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "dueDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "priority": {
            "$ref": "#/components/schemas/Priority"
          },
          "isCompleted": {
            "type": "boolean"
          },
          "completedAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rowVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "uint32"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "description": "Wire shape for a todo. <strong>UserId is intentionally absent</strong> — the\nglobal query filter and ownership tests both lean on responses never leaking\nuser identifiers."
      },
      "UpdateTodoRequest": {
        "required": [
          "title",
          "description",
          "dueDate",
          "priority",
          "tags",
          "rowVersion"
        ],
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "dueDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "priority": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Priority"
              }
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rowVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "uint32"
          }
        },
        "description": "Full-replacement update payload. PUT semantics — every field must round-trip."
      }
    }
  },
  "tags": [
    {
      "name": "AuthEndpoints"
    },
    {
      "name": "TodoEndpoints"
    },
    {
      "name": "TodoApp.Api"
    }
  ]
}