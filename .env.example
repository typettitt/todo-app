# Production compose example. Keep the real signing-key file out of git.
TODOAPP_IMAGE_TAG=latest
TODOAPP_WEB_BIND=127.0.0.1:8080
TODOAPP_CONNECTION_STRING="Data Source=/var/lib/todoapp/todoapp.db"
TODOAPP_JWT_SIGNING_KEY_FILE=./secrets/jwt_signing_key
TODOAPP_INTERNAL_HEALTH_HEADER=replace-me-with-random-health-probe-secret
TODOAPP_TRUST_KNOWN_PROXIES=172.16.0.0/12
