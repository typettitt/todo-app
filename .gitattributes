# Default: cross-platform line endings normalized to LF in the repo.
* text=auto eol=lf

# Source code
*.cs       text eol=lf diff=csharp
*.csx      text eol=lf diff=csharp
*.vb       text eol=lf
*.fs       text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.html     text eol=lf

# Project / build files
*.sln      text eol=lf
*.slnx     text eol=lf
*.csproj   text eol=lf
*.vbproj   text eol=lf
*.fsproj   text eol=lf
*.proj     text eol=lf
*.props    text eol=lf
*.targets  text eol=lf
*.config   text eol=lf
*.nuspec   text eol=lf

# Data / docs
*.json     text eol=lf
*.xml      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.txt      text eol=lf

# Shell / scripts — Windows hosts need CRLF for cmd/bat/ps; sh stays LF.
*.sh       text eol=lf
*.ps1      text eol=lf
*.psm1     text eol=lf
*.cmd      text eol=crlf
*.bat      text eol=crlf

# Binary assets
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      text eol=lf
*.pdf      binary
*.zip      binary
*.gz       binary
*.7z       binary
*.tar      binary
*.dll      binary
*.exe      binary
*.pdb      binary
*.snk      binary
*.nupkg    binary
*.snupkg   binary
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
*.db       binary
